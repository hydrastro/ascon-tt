# Local build/simulation products
/build/
/runs/
*.vvp
*.vcd
*.fst

# Python local env/cache
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# Generated local vector headers
/sim/generated/

# Patch/archive leftovers
*.rej
*.orig
*.patch
*.zip
*.tar.gz

# Hardening/layout artifacts
/artifacts/runs/*
!/artifacts/runs/.gitkeep
*.gds
*.def
*.lef
*.spef
*.sdf
*.mag
*.spice
*.spef.gz

# Keep artifact manifests trackable
!/artifacts/manifests/
!/artifacts/manifests/.gitkeep

# Tiny Tapeout support tools caches only; do not ignore tt/ itself if it is a submodule
tt/__pycache__/
tt/**/*.pyc

.ttsetup/
