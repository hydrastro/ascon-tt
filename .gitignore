# Local build/simulation products
/build/
/runs/
*.vvp
*.vcd
*.fst
*.fst.hier

# Python local env/cache
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# Generated local vector headers
/sim/generated/

# Tiny Tapeout generated config
/src/user_config.json
/src/config_merged.json
/tt_submission/
/gds_render.png

# Hardening/layout artifacts
/artifacts/runs/*
!/artifacts/runs/.gitkeep
*.gds
*.gds.gz
*.def
*.lef
*.spef
*.sdf
*.mag
*.spice
*.spef.gz

# Keep manifests trackable
!/artifacts/manifests/
!/artifacts/manifests/.gitkeep

# Patch/archive leftovers
*.rej
*.orig
*.patch
*.zip
*.tar.gz

# Nix/local PDK
.ttsetup/
.direnv/
result
result-*

# Tiny Tapeout support tool caches only; do not ignore tt/ itself if it is a submodule
tt/__pycache__/
tt/**/*.pyc
